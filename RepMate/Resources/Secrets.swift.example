// Copy this file to Secrets.swift and fill in your real values.
// ⚠️ Secrets.swift is gitignored — NEVER commit it.
// The matching value must be set as APP_SECRET in your AWS Lambda environment variables.

enum Secrets {
    static var appSecretKey: String {
        SecretHardener.decode(SecretHardener.appSecretKeyBytes)
    }
    
    static var aiPlanEndpointString: String {
        SecretHardener.decode(SecretHardener.aiPlanEndpointBytes)
    }
    
    static var aiProteinEndpointString: String {
        SecretHardener.decode(SecretHardener.aiProteinEndpointBytes)
    }
}
